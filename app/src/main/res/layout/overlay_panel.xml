<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/panel_bg"
    android:padding="16dp"
    android:elevation="16dp">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="N E M O"
            android:textSize="14sp"
            android:textColor="#00F5FF"
            android:fontFamily="monospace"
            android:letterSpacing="0.3" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#8888AA" />

    </LinearLayout>

    <!-- Status line -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textSize="11sp"
        android:textColor="#00AA88"
        android:fontFamily="monospace"
        android:layout_marginBottom="10dp" />

    <!-- Response text -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ask me anything!"
            android:textSize="14sp"
            android:textColor="#CCCCDD"
            android:lineSpacingMultiplier="1.5"
            android:minHeight="60dp" />

    </ScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#222244"
        android:layout_marginBottom="12dp" />

    <!-- READ SCREEN BUTTON (Layer 2) -->
    <Button
        android:id="@+id/btnReadScreen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👁  Read My Screen"
        android:textColor="#0A0A1A"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:backgroundTint="#00CCAA"
        android:layout_marginBottom="12dp" />

    <!-- Input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="@drawable/mic_button_bg"
            android:tint="#00F5FF"
            android:padding="10dp"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/etInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Type or tap mic…"
            android:textColor="#CCCCDD"
            android:textSize="13sp"
            android:background="#0D0D1F"
            android:padding="10dp"
            android:maxLines="3"
            android:imeOptions="actionSend"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEND"
            android:textColor="#0A0A1A"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:backgroundTint="#00F5FF" />

    </LinearLayout>

</LinearLayout>
