<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/panel_bg"
    android:padding="16dp"
    android:elevation="16dp">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NEMO"
            android:textSize="14sp"
            android:textColor="#00F5FF"
            android:fontFamily="monospace"
            android:letterSpacing="0.3" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#8888AA" />

    </LinearLayout>

    <!-- Status line -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textSize="11sp"
        android:textColor="#00AA88"
        android:fontFamily="monospace"
        android:layout_marginBottom="10dp" />

    <!-- Response text -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap the mic and speak."
            android:textSize="14sp"
            android:textColor="#CCCCDD"
            android:lineSpacingMultiplier="1.5"
            android:minHeight="60dp" />

    </ScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#222244"
        android:layout_marginBottom="12dp" />

    <!-- Mic button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="@drawable/mic_button_bg"
            android:tint="#00F5FF"
            android:contentDescription="Speak to Nemo"
            android:padding="12dp" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="tap to speak"
        android:textSize="11sp"
        android:textColor="#555577"
        android:gravity="center"
        android:fontFamily="monospace"
        android:layout_marginTop="6dp" />

</LinearLayout>
