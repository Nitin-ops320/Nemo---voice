<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Logo/Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEMO"
            android:textSize="48sp"
            android:textColor="#00F5FF"
            android:fontFamily="monospace"
            android:letterSpacing="0.3"
            android:layout_marginTop="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your AI Assistant"
            android:textSize="14sp"
            android:textColor="#8888AA"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="48dp" />

        <!-- API Key Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2E"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GEMINI API KEY"
                android:textSize="11sp"
                android:textColor="#00F5FF"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Get your free key at: aistudio.google.com"
                android:textSize="12sp"
                android:textColor="#8888AA"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Paste your API key here"
                android:textColor="#CCCCDD"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:background="#0D0D1F"
                android:padding="12dp"
                android:inputType="textPassword"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnSaveKey"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="SAVE KEY"
                android:textColor="#00F5FF"
                android:background="#0D1530"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Launch Button -->
        <Button
            android:id="@+id/btnLaunchNemo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  LAUNCH NEMO"
            android:textColor="#0A0A1A"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:backgroundTint="#00F5FF"
            android:layout_marginBottom="12dp" />

        <!-- Stop Button -->
        <Button
            android:id="@+id/btnStopNemo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="■  STOP NEMO"
            android:textColor="#FF4466"
            android:background="#1A0A0E"
            android:fontFamily="monospace"
            android:layout_marginBottom="32dp" />

        <!-- Instructions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111122"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOW IT WORKS"
                android:textSize="11sp"
                android:textColor="#00F5FF"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Paste your Gemini API key and save it\n2. Tap LAUNCH NEMO\n3. Allow all permissions when asked\n4. A floating cyan bubble will appear\n5. Tap the bubble to open the panel\n6. Tap the mic button and speak\n7. Nemo listens, thinks, and replies by voice\n\nThe bubble floats above ALL apps — even YouTube, WhatsApp, everything."
                android:textSize="13sp"
                android:textColor="#8888AA"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5" />

        </LinearLayout>

    </LinearLayout>
</ScrollView><?xml version="1.0" encoding="utf-8"?>
